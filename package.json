{
  "name": "app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "node --max-old-space-size=320 ./node_modules/next/dist/bin/next start",
    "lint": "biome check .",
    "format": "biome format . --write",
    "lint:fix": "biome check . --apply",
